# ============================================================
#  Variables de entorno - Copia este archivo a .env y completa
# ============================================================

# ---- Aplicación ----
APP_NAME="Sistema Inteligente de Solicitudes Universitarias"
APP_ENV=development

# ---- Azure OpenAI ----
# Azure AI Foundry -> tu proyecto -> "Models + endpoints"
AZURE_OPENAI_API_KEY=tu_api_key_de_azure_aqui
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
# Nombre del DEPLOYMENT (no el nombre del modelo), ej: gpt-4o-mini-1
AZURE_OPENAI_DEPLOYMENT=tu_deployment_aqui
AZURE_OPENAI_API_VERSION=2024-10-21
LLM_TEMPERATURE=0.1

# ---- Base de datos (Azure Database for PostgreSQL) ----
# Azure Portal -> tu servidor PostgreSQL -> Connect -> cadena de conexión.
# Formato: postgresql+psycopg://usuario:password@servidor.postgres.database.azure.com:5432/nombre_bd?sslmode=require
DATABASE_URL=postgresql+psycopg://usuario:password@tu-servidor.postgres.database.azure.com:5432/postgres?sslmode=require
